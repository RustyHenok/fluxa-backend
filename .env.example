APP_NAME=fluxa-backend
APP_MODE=all
HTTP_ADDR=0.0.0.0:8080
GRPC_ADDR=0.0.0.0:50051
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/fluxa
REDIS_URL=redis://127.0.0.1/
JWT_SECRET=replace-with-a-32-character-secret-at-minimum
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
CACHE_TTL_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=3600
AUTH_RATE_LIMIT_CAPACITY=10
AUTH_RATE_LIMIT_REFILL_PER_SEC=2
APP_RATE_LIMIT_CAPACITY=120
APP_RATE_LIMIT_REFILL_PER_SEC=30
JOB_QUEUE_NAME=jobs:queue:default
WORKER_DISPATCH_INTERVAL_MS=3000
WORKER_SCHEDULER_INTERVAL_MS=60000
JOB_QUEUE_BLOCK_TIMEOUT_SECONDS=5
MAX_JOB_ATTEMPTS=5
DATABASE_MAX_CONNECTIONS=10
STARTUP_MAX_RETRIES=20
STARTUP_RETRY_DELAY_MS=1500
CORS_ALLOW_ORIGIN=*
